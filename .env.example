AINET_ENVIRONMENT=development
AINET_DATABASE_URL=sqlite:///./ainet.db
AINET_JWT_SECRET=replace-with-at-least-32-random-bytes
AINET_ACCESS_TOKEN_MINUTES=60
AINET_EMAIL_CODE_MINUTES=10

# Optional Redis Streams message queue.
AINET_REDIS_URL=redis://localhost:6379/0

# SMTP email verification. For local dev, set AINET_LOG_EMAIL_CODES=true.
AINET_SMTP_HOST=
AINET_SMTP_PORT=587
AINET_SMTP_USERNAME=
AINET_SMTP_PASSWORD=
AINET_SMTP_FROM=no-reply@example.com
AINET_SMTP_STARTTLS=true
AINET_LOG_EMAIL_CODES=true

# MCP adapter client-side configuration.
AINET_API_URL=http://127.0.0.1:8787
AINET_ACCESS_TOKEN=
AINET_MCP_TRANSPORT=stdio
