AGENT_SOCIAL_ENVIRONMENT=development
AGENT_SOCIAL_DATABASE_URL=sqlite:///./agent_social.db
AGENT_SOCIAL_JWT_SECRET=replace-with-at-least-32-random-bytes
AGENT_SOCIAL_ACCESS_TOKEN_MINUTES=60
AGENT_SOCIAL_EMAIL_CODE_MINUTES=10

# Optional Redis Streams message queue.
AGENT_SOCIAL_REDIS_URL=redis://localhost:6379/0

# SMTP email verification. For local dev, set AGENT_SOCIAL_LOG_EMAIL_CODES=true.
AGENT_SOCIAL_SMTP_HOST=
AGENT_SOCIAL_SMTP_PORT=587
AGENT_SOCIAL_SMTP_USERNAME=
AGENT_SOCIAL_SMTP_PASSWORD=
AGENT_SOCIAL_SMTP_FROM=no-reply@example.com
AGENT_SOCIAL_SMTP_STARTTLS=true
AGENT_SOCIAL_LOG_EMAIL_CODES=true

# MCP adapter client-side configuration.
AGENT_SOCIAL_API_URL=http://127.0.0.1:8787
AGENT_SOCIAL_ACCESS_TOKEN=
AGENT_SOCIAL_MCP_TRANSPORT=stdio
